# DB
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Used to authorize cron invocations
CRON_SECRET=generate_a_strong_random_string

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=ph_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://<us | eu>.i.posthog.com

# Maintenance mode
MAINTENANCE_MODE=false

# AI
AI_PROVIDER=openai
AI_PROVIDER_API_KEY=your_provider_api_key
AI_CHAT_MODEL_ID=gpt-5.4-mini
AI_EXTRACTION_MODEL_ID=gpt-5.4-mini

# Replicate API
REPLICATE_API_TOKEN=your_replicate_api_token

# Discord Feedback Webhook
DISCORD_FEEDBACK_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Automated emails
AUTOMATED_EMAILS_ENABLED=false
RESEND_API_KEY=your_resend_api_key
EMAILS_FROM_ADDRESS="Foliofox <notifications@your-domain.com>"
EMAIL_LINK_SECRET=generate_a_long_random_secret
